# Copy to .env and fill in. Tests read configuration from the environment.
BASE_URL={{ base_url }}
{% if auth_kind == "bearer" %}
# Bearer token sent as the Authorization header.
AUTH_TOKEN=
{% elif auth_kind == "apikey" %}
# API key sent as the "{{ auth_header_name }}" {{ auth_in }}.
AUTH_TOKEN=
{% elif auth_kind == "basic" %}
# HTTP Basic credentials.
AUTH_USER=
AUTH_PASS=
{% elif auth_kind == "session" %}
# Login form discovered — credentials for the authenticated_page fixture's login flow.
AUTH_USER=
AUTH_PASS=
{% else %}
# No authentication was discovered.
{% endif %}
