{
  "openapi": "3.0.3",
  "info": {
    "title": "Rick and Morty API",
    "version": "1.0.0",
    "description": "Public read-only REST API for Rick and Morty characters, locations, and episodes. No authentication. Spec reconstructed from the live API at https://rickandmortyapi.com/api."
  },
  "servers": [{ "url": "https://rickandmortyapi.com/api" }],
  "paths": {
    "/character": {
      "get": {
        "operationId": "listCharacters",
        "summary": "List and filter characters (paginated)",
        "tags": ["character"],
        "parameters": [
          { "name": "page", "in": "query", "required": false, "schema": { "type": "integer" }, "description": "Page number (20 results per page)." },
          { "name": "name", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "status", "in": "query", "required": false, "schema": { "type": "string", "enum": ["alive", "dead", "unknown"] } },
          { "name": "species", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "type", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "gender", "in": "query", "required": false, "schema": { "type": "string", "enum": ["female", "male", "genderless", "unknown"] } }
        ],
        "responses": {
          "200": { "description": "Paginated list of characters", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CharacterList" } } } },
          "404": { "description": "No characters matched the filters" }
        }
      }
    },
    "/character/{id}": {
      "get": {
        "operationId": "getCharacter",
        "summary": "Get a single character by id",
        "tags": ["character"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "Character id. A comma-separated list returns an array of characters." }
        ],
        "responses": {
          "200": { "description": "A character", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Character" } } } },
          "404": { "description": "Character not found" }
        }
      }
    },
    "/location": {
      "get": {
        "operationId": "listLocations",
        "summary": "List and filter locations (paginated)",
        "tags": ["location"],
        "parameters": [
          { "name": "page", "in": "query", "required": false, "schema": { "type": "integer" } },
          { "name": "name", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "type", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "dimension", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Paginated list of locations", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LocationList" } } } },
          "404": { "description": "No locations matched the filters" }
        }
      }
    },
    "/location/{id}": {
      "get": {
        "operationId": "getLocation",
        "summary": "Get a single location by id",
        "tags": ["location"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "A location", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Location" } } } },
          "404": { "description": "Location not found" }
        }
      }
    },
    "/episode": {
      "get": {
        "operationId": "listEpisodes",
        "summary": "List and filter episodes (paginated)",
        "tags": ["episode"],
        "parameters": [
          { "name": "page", "in": "query", "required": false, "schema": { "type": "integer" } },
          { "name": "name", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "episode", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Episode code, e.g. S01E01." }
        ],
        "responses": {
          "200": { "description": "Paginated list of episodes", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EpisodeList" } } } },
          "404": { "description": "No episodes matched the filters" }
        }
      }
    },
    "/episode/{id}": {
      "get": {
        "operationId": "getEpisode",
        "summary": "Get a single episode by id",
        "tags": ["episode"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "An episode", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Episode" } } } },
          "404": { "description": "Episode not found" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Info": {
        "type": "object",
        "properties": {
          "count": { "type": "integer" },
          "pages": { "type": "integer" },
          "next": { "type": "string", "nullable": true },
          "prev": { "type": "string", "nullable": true }
        }
      },
      "ResourceRef": {
        "type": "object",
        "properties": { "name": { "type": "string" }, "url": { "type": "string" } }
      },
      "Character": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "species": { "type": "string" },
          "type": { "type": "string" },
          "gender": { "type": "string" },
          "origin": { "$ref": "#/components/schemas/ResourceRef" },
          "location": { "$ref": "#/components/schemas/ResourceRef" },
          "image": { "type": "string" },
          "episode": { "type": "array", "items": { "type": "string" } },
          "url": { "type": "string" },
          "created": { "type": "string" }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "dimension": { "type": "string" },
          "residents": { "type": "array", "items": { "type": "string" } },
          "url": { "type": "string" },
          "created": { "type": "string" }
        }
      },
      "Episode": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "air_date": { "type": "string" },
          "episode": { "type": "string" },
          "characters": { "type": "array", "items": { "type": "string" } },
          "url": { "type": "string" },
          "created": { "type": "string" }
        }
      },
      "CharacterList": {
        "type": "object",
        "properties": {
          "info": { "$ref": "#/components/schemas/Info" },
          "results": { "type": "array", "items": { "$ref": "#/components/schemas/Character" } }
        }
      },
      "LocationList": {
        "type": "object",
        "properties": {
          "info": { "$ref": "#/components/schemas/Info" },
          "results": { "type": "array", "items": { "$ref": "#/components/schemas/Location" } }
        }
      },
      "EpisodeList": {
        "type": "object",
        "properties": {
          "info": { "$ref": "#/components/schemas/Info" },
          "results": { "type": "array", "items": { "$ref": "#/components/schemas/Episode" } }
        }
      }
    }
  }
}
